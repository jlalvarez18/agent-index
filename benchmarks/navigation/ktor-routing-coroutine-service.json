      ]
    },
    "expected": {
      "files": [
        "ktor-server/ktor-server-core/common/src/io/ktor/server/routing/RoutingNode.kt",
        "ktor-server/ktor-server-core/common/src/io/ktor/server/routing/RoutingRoot.kt"
      ],
      "symbols": ["RoutingNode", "Route", "executeResult"],
      "requiredFiles": ["ktor-server/ktor-server-core/common/src/io/ktor/server/routing/RoutingNode.kt"],
      "requiredSymbols": ["RoutingNode"]
