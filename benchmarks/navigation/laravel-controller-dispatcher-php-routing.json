    "agentIndexSteps": [
      {
        "type": "file-clusters",
        "query": {
          "terms": ["ControllerDispatcher", "callAction", "controller", "parameters", "middleware"],
          "symbolKinds": ["class", "method"],
          "roles": ["source"],
          "pathHints": ["src/Illuminate/Routing"]
        },
        "limit": 5
      },
      {
        "type": "related-tests",
        "sourceFromStep": 1,
        "symbol": "Illuminate\\Routing\\ControllerDispatcher::dispatch",
