[
  {
    "id": "pydantic-computed-fields-python-api",
    "task": "Find the Python API surface for computed-field serialization and exclude_computed_fields behavior.",
    "kind": "test-discovery",
    "agentIndexQueries": [
      {
        "terms": ["model_dump", "model_dump_json", "exclude_computed_fields", "computed_field"],
        "symbolKinds": ["method", "function"],
        "roles": ["source"],
        "pathHints": ["pydantic/main.py", "pydantic/fields.py"],
        "expand": ["callees"]
      },
      {
        "terms": ["exclude_computed_fields"],
        "symbolKinds": ["function"],
        "roles": ["test"],
        "pathHints": ["tests/test_computed_fields.py"],
        "pathMode": "filter",
        "expand": []
      }
    ],
    "rgQueries": [
      ["exclude_computed_fields", "computed_field", "model_dump", "model_dump_json"],
      ["exclude_computed_fields", "test_computed", "model_dump_json"]
    ],
    "rgOptimizedSteps": [
      {
        "type": "files",
        "terms": ["exclude_computed_fields"],
        "paths": ["pydantic"],
        "globs": ["*.py"],
        "limit": 25
      },
      {
        "type": "snippets",
        "terms": ["exclude_computed_fields", "computed_field", "model_dump", "model_dump_json"],
        "fromStep": 1,
        "limit": 5
      },
      {
        "type": "files",
        "terms": ["exclude_computed_fields"],
        "paths": ["tests"],
        "globs": ["*test*.py"],
        "limit": 25
      },
      {
        "type": "snippets",
        "terms": ["exclude_computed_fields"],
        "fromStep": 3,
        "limit": 5
      }
    ],
    "expected": {
      "files": ["pydantic/main.py", "pydantic/fields.py", "tests/test_computed_fields.py"],
      "symbols": ["BaseModel.model_dump", "BaseModel.model_dump_json", "computed_field"]
    }
  },
  {
    "id": "pydantic-computed-fields-rust-core",
    "task": "Find the Rust serializer implementation that controls computed-field serialization.",
    "kind": "maintenance",
    "agentIndexQueries": [
      {
        "terms": ["ComputedFields.serialize", "computed_fields", "exclude_computed_fields"],
        "symbolKinds": ["method"],
        "roles": ["source"],
        "pathHints": ["pydantic-core/src/serializers"],
        "expand": []
      }
    ],
    "rgQueries": [
      ["ComputedFields", "serialize", "exclude_computed_fields", "computed_fields"]
    ],
    "rgOptimizedSteps": [
      {
        "type": "files",
        "terms": ["ComputedFields"],
        "paths": ["pydantic-core/src"],
        "limit": 25
      },
      {
        "type": "snippets",
        "terms": ["ComputedFields"],
        "before": 20,
        "after": 20,
        "fromStep": 1,
        "limit": 5
      }
    ],
    "expected": {
      "files": ["pydantic-core/src/serializers/computed_fields.rs"],
      "symbols": ["ComputedFields.serialize"]
    }
  }
]
