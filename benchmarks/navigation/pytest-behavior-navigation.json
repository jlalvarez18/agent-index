[
  {
    "id": "pytest-capture-suspend-resume-behavior-only",
    "task": "Find where pytest suspends and resumes stdout/stderr capture around test execution and the related tests, without naming the capture manager API.",
    "kind": "bugfix",
    "agentIndexSteps": [
      {
        "type": "file-clusters",
        "query": {
          "terms": ["stdout", "stderr", "capture", "suspend", "resume"],
          "symbolKinds": ["method", "function"],
          "roles": ["source"]
        },
        "limit": 8
      },
      {
        "type": "related-tests",
        "sourceFromStep": 1,
        "terms": ["stdout", "stderr", "capture"],
        "limit": 8
      }
    ],
    "rgQueries": [
      ["stdout", "stderr", "capture", "suspend", "resume"],
      ["stdout", "stderr", "capture", "test"]
    ],
    "rgOptimizedSteps": [
      {
        "type": "files",
        "terms": ["stdout", "stderr", "capture", "suspend", "resume"],
        "paths": ["src"],
        "globs": ["*.py"],
        "limit": 25
      },
      {
        "type": "snippets",
        "terms": ["stdout", "stderr", "capture", "suspend", "resume"],
        "fromStep": 1,
        "limit": 5
      },
      {
        "type": "files",
        "terms": ["stdout", "stderr", "capture"],
        "paths": ["testing"],
        "globs": ["*test*.py"],
        "limit": 25
      },
      {
        "type": "snippets",
        "terms": ["stdout", "stderr", "capture"],
        "fromStep": 3,
        "limit": 5
      }
    ],
    "expected": {
      "files": ["src/_pytest/capture.py", "testing/test_capture.py"],
      "symbols": ["CaptureManager.item_capture"],
      "requiredFiles": ["src/_pytest/capture.py", "testing/test_capture.py"],
      "requiredSymbols": ["CaptureManager.item_capture"]
    }
  },
  {
